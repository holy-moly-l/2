```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Logs
*.log

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/

# Testing
.coverage
htmlcov/
.coverage.*
.nyc_output
istanbul*
.mypy_cache/
.pytest_cache/
.hypothesis/

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
```